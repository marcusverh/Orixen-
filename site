        <button class="faq-q" onclick="tFaq(this)">Mon territoire est-il réellement exclusif ?<span class="faq-chev"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4l4 4 4-4"/></svg></span></button>
        <div class="faq-ans"><div class="faq-ans-in">Oui, sans exception. Lorsqu'une zone est attribuée, nous refusons toute collaboration concurrente sur ce périmètre. C'est une règle structurelle, pas un argument commercial.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="tFaq(this)">Est-ce un appel de vente ?<span class="faq-chev"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4l4 4 4-4"/></svg></span></button>
        <div class="faq-ans"><div class="faq-ans-in">L'audit stratégique est un échange de 30 à 45 minutes. Nous analysons votre situation : territoire, potentiel d'acquisition, vitesse de réponse, processus de conversion. Si aucune opportunité claire n'est identifiée, nous ne proposons rien.</div></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" onclick="tFaq(this)">Le budget publicitaire est-il inclus ?<span class="faq-chev"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 4l4 4 4-4"/></svg></span></button>
        <div class="faq-ans"><div class="faq-ans-in">Non. Le budget publicitaire est géré directement par vous via votre compte Meta. Nos honoraires couvrent la stratégie, la création des campagnes, l'infrastructure de qualification et le suivi. Vous gardez la main sur votre investissement.</div></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ CTA ═══ -->

<section id="cta">
  <div class="wrap">
    <div class="cta-wrap">
      <p class="eyebrow reveal">Passez à l'étape suivante</p>
      <h2 class="h2 reveal d1">Si vos leads ne sont pas contactés assez vite, vous perdez déjà des opportunités.</h2>
      <p class="body-text reveal d2" style="text-align:center;margin:0 auto 40px">Réservez un audit stratégique et découvrez comment Orixen peut structurer une acquisition plus claire, plus mesurable et plus rentable.</p>
      <div class="reveal d3">
        <a href="confirmation.html" class="btn-filled" style="display:inline-flex">
          Réserver un audit stratégique
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="M1 7h12M8 2l5 5-5 5"/></svg>
        </a>
        <p class="cta-micro">Disponibilités volontairement limitées par zone.</p>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="f-logo">
    <svg viewBox="0 0 22 22" fill="none"><rect width="22" height="22" rx="6" fill="#0071e3"/><path d="M6 11 L10.5 6.5 L15 11 L10.5 15.5 Z" fill="none" stroke="white" stroke-width="1.6" stroke-linejoin="round"/><circle cx="18" cy="11" r="2" fill="white"/></svg>
    Orixen
  </div>
  <div class="f-copy">© 2025 Orixen — Infrastructure d'acquisition pour le bâtiment</div>
</footer>

<script>
/* CURSOR */
const cur=document.getElementById('cursor'),trail=document.getElementById('cursor-t');
let mx=0,my=0,tx=0,ty=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
(function animT(){tx+=(mx-tx)*.1;ty+=(my-ty)*.1;trail.style.left=tx+'px';trail.style.top=ty+'px';requestAnimationFrame(animT)})();
document.querySelectorAll('a,button,.sc,.result-card,.hero-tag,.how-step,.bi,.kpi,.faq-q').forEach(el=>{
  el.addEventListener('mouseenter',()=>cur.classList.add('h'));
  el.addEventListener('mouseleave',()=>cur.classList.remove('h'));
});
document.addEventListener('mousedown',()=>cur.classList.add('c'));
document.addEventListener('mouseup',()=>cur.classList.remove('c'));
if('ontouchstart' in window){cur.style.display='none';trail.style.display='none';document.body.style.cursor='auto'}

/* PROGRESS */
const prog=document.getElementById('prog');
window.addEventListener('scroll',()=>{const h=document.documentElement;prog.style.width=(h.scrollTop/(h.scrollHeight-h.clientHeight)*100)+'%'},{passive:true});

/* NAV */
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>20),{passive:true});

/* REVEAL */
const io=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target)}}),{threshold:.08,rootMargin:'0px 0px -20px 0px'});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

/* SPLIT TEXT */
(function(){
  const h1=document.querySelector('.hero-h1');
  if(!h1)return;
  function wrap(node){
    if(node.nodeType===3){
      const words=node.textContent.split(/(\s+)/);
      const frag=document.createDocumentFragment();
      words.forEach(w=>{
        if(/^\s+$/.test(w)||w===''){frag.appendChild(document.createTextNode(w))}
        else{const s=document.createElement('span');s.className='word';const i=document.createElement('span');i.className='wi';i.textContent=w;s.appendChild(i);frag.appendChild(s)}
      });
      node.parentNode.replaceChild(frag,node);
    } else if(node.nodeType===1){Array.from(node.childNodes).forEach(wrap)}
  }
  Array.from(h1.childNodes).forEach(wrap);
  h1.querySelectorAll('.wi').forEach((w,i)=>{w.style.transitionDelay=(0.35+i*.07)+'s'});
  setTimeout(()=>h1.classList.add('revealed'),80);
})();

/* COUNT UP */
function countUp(el,target,prefix,suffix,dur){
  let v=0;const step=target/(dur/16);
  const t=setInterval(()=>{v=Math.min(v+step,target);el.textContent=(prefix||'')+Math.round(v)+(suffix||'');if(v>=target)clearInterval(t)},16);
}
const cio=new IntersectionObserver(e=>e.forEach(x=>{
  if(x.isIntersecting){
    const el=x.target;
    countUp(el,parseInt(el.dataset.count),el.dataset.prefix||'',el.dataset.suffix!==undefined?el.dataset.suffix:'',1400);
    cio.unobserve(el);
  }
}),{threshold:.5});
document.querySelectorAll('[data-count]').forEach(el=>cio.observe(el));

/* TERRITORY */
const taken=['75001','75002','75008','69001','13001','33000','31000','06000','59000','67000'];
function checkTerr(){
  const v=document.getElementById('terr-in').value.trim();
  const res=document.getElementById('terr-res');
  const mc=document.getElementById('mc');
  const rings=[document.getElementById('mr1'),document.getElementById('mr2'),document.getElementById('mr3')];
  if(!/^\d{5}$/.test(v)){res.className='terr-res loading';res.style.display='flex';res.innerHTML='<div class="tr-dot tr-dot-l"></div>Veuillez saisir un code postal valide.';return}
  res.className='terr-res loading';res.style.display='flex';res.innerHTML='<div class="tr-dot tr-dot-l"></div>Vérification en cours...';
  setTimeout(()=>{
    if(taken.includes(v)){
      res.className='terr-res taken';res.innerHTML='<div class="tr-dot tr-dot-r"></div>Zone <strong style="margin:0 3px">'+v+'</strong> — déjà attribuée. Contactez-nous pour la liste d\'attente.';
      mc.classList.add('taken');rings.forEach(r=>r.classList.add('taken'));
    } else {
      res.className='terr-res free';res.innerHTML='<div class="tr-dot tr-dot-g"></div>Zone <strong style="margin:0 3px">'+v+'</strong> — disponible ! Réservez votre territoire maintenant.';
      mc.classList.remove('taken');rings.forEach(r=>r.classList.remove('taken'));
    }
  },900);
}
document.getElementById('terr-in').addEventListener('keydown',e=>{if(e.key==='Enter')checkTerr()});

/* FAQ */
function tFaq(btn){
  const body=btn.nextElementSibling,isOpen=btn.classList.contains('open');
  document.querySelectorAll('.faq-q.open').forEach(b=>{b.classList.remove('open');b.nextElementSibling.classList.remove('open')});
  if(!isOpen){btn.classList.add('open');body.classList.add('open')}
}
</script>

</body>
</html>
