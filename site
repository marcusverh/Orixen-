<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Orixen — Infrastructure d'acquisition</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet"/>

<!-- Favicon SVG inline -->

<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%230071e3'/><path d='M8 16 L14 10 L20 16 L14 22 Z' fill='none' stroke='white' stroke-width='2' stroke-linejoin='round'/><circle cx='22' cy='16' r='3' fill='white'/></svg>"/>

<style>
:root{
  --surface:#fbfbfd;--bg:#f5f5f7;--card:#fff;
  --line:#d2d2d7;--line-hi:#e8e8ed;
  --ink:#1d1d1f;--ink-3:#6e6e73;--ink-4:#aeaeb2;
  --blue:#0071e3;--blue-hi:#0077ed;--blue-lo:rgba(0,113,227,.08);--blue-mid:rgba(0,113,227,.18);
  --green:#30a64a;--green-bg:rgba(48,166,74,.08);
  --font:'Plus Jakarta Sans',-apple-system,BlinkMacSystemFont,sans-serif;
  --ease:cubic-bezier(.25,.46,.45,.94);
  --spring:cubic-bezier(.34,1.56,.64,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
body{background:var(--surface);color:var(--ink);font-family:var(--font);line-height:1.5;overflow-x:hidden;cursor:none}
a{color:inherit;text-decoration:none}
button{border:none;background:none;cursor:none;font-family:inherit}
::-webkit-scrollbar{width:0}

/* CURSOR */
#cursor{position:fixed;top:0;left:0;z-index:9999;pointer-events:none;width:10px;height:10px;background:var(--blue);border-radius:50%;transform:translate(-50%,-50%);transition:width .25s var(--spring),height .25s var(--spring),background .2s;will-change:transform}
#cursor.h{width:44px;height:44px;background:rgba(0,113,227,.12);border:1.5px solid var(--blue)}
#cursor.c{width:7px;height:7px}
#cursor-t{position:fixed;top:0;left:0;z-index:9998;pointer-events:none;width:36px;height:36px;border:1px solid rgba(0,113,227,.28);border-radius:50%;transform:translate(-50%,-50%);opacity:.55;will-change:transform}

/* PROGRESS */
#prog{position:fixed;top:0;left:0;z-index:1000;height:2px;width:0%;background:linear-gradient(90deg,var(--blue),#34aaff);pointer-events:none;transition:width .08s linear}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;background:rgba(245,245,247,.82);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);border-bottom:1px solid transparent;transition:border-color .3s}
nav.scrolled{border-color:var(--line)}
.nav-logo{display:flex;align-items:center;gap:9px;font-size:1.05rem;font-weight:800;letter-spacing:-.03em;color:var(--ink)}
.nav-logo svg{width:26px;height:26px}
.nav-links{display:flex;align-items:center;gap:28px;list-style:none}
.nav-links a{font-size:.78rem;font-weight:400;color:var(--ink-3);transition:color .2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;right:0;height:1px;background:var(--blue);transform:scaleX(0);transition:transform .2s var(--ease)}
.nav-links a:hover{color:var(--ink)}.nav-links a:hover::after{transform:scaleX(1)}
.nav-btn{font-size:.78rem;font-weight:600;color:#fff;background:var(--blue);padding:8px 18px;border-radius:980px;transition:background .2s,transform .15s,box-shadow .2s}
.nav-btn:hover{background:var(--blue-hi);transform:scale(1.02);box-shadow:0 4px 16px rgba(0,113,227,.35)}
@media(max-width:680px){.nav-links{display:none}}

/* REVEAL */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .75s var(--ease),transform .75s var(--ease)}
.reveal.in{opacity:1;transform:none}
.d1{transition-delay:.08s}.d2{transition-delay:.16s}.d3{transition-delay:.24s}.d4{transition-delay:.32s}

/* SPLIT TEXT */
.split-text .word{display:inline-block;overflow:hidden;vertical-align:bottom;padding-bottom:.05em}
.split-text .wi{display:inline-block;transform:translateY(110%);transition:transform .75s var(--spring)}
.split-text.revealed .wi{transform:translateY(0)}

/* ────── HERO ────── */
#hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:120px 24px 60px;background:var(--surface);position:relative;overflow:hidden}
#hero::before{content:'';position:absolute;top:-15%;left:50%;transform:translateX(-50%);width:1000px;height:600px;background:radial-gradient(ellipse 65% 55% at 50% 40%,rgba(0,113,227,.08),transparent 70%);pointer-events:none}
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(0,113,227,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,113,227,.04) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 70% at 50% 50%,black 30%,transparent 80%);-webkit-mask-image:radial-gradient(ellipse 80% 70% at 50% 50%,black 30%,transparent 80%)}
.hero-inner{max-width:820px;position:relative;z-index:1}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:.78rem;font-weight:600;color:var(--blue);margin-bottom:24px;opacity:0;animation:fadeUp .8s var(--ease) .1s forwards}
.eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);animation:pdot 2s ease-in-out infinite}
@keyframes pdot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.6)}}
.hero-h1{font-size:clamp(2.8rem,6vw,5.8rem);font-weight:800;line-height:1.04;letter-spacing:-.04em;color:var(--ink);margin-bottom:28px}
.hero-h1 .blue{color:var(--blue)}
.hero-sub{font-size:clamp(.98rem,1.8vw,1.2rem);font-weight:400;line-height:1.65;color:var(--ink-3);max-width:580px;margin:0 auto 44px;opacity:0;animation:fadeUp .9s var(--ease) .9s forwards}
.hero-actions{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:52px;opacity:0;animation:fadeUp .9s var(--ease) 1.05s forwards}
.btn-filled{display:inline-flex;align-items:center;gap:8px;font-size:.9rem;font-weight:600;color:#fff;background:var(--blue);padding:14px 28px;border-radius:980px;transition:background .2s,transform .2s,box-shadow .2s;box-shadow:0 2px 12px rgba(0,113,227,.25)}
.btn-filled:hover{background:var(--blue-hi);transform:translateY(-1px) scale(1.01);box-shadow:0 8px 28px rgba(0,113,227,.38)}
.btn-filled svg,.btn-link svg{width:14px;height:14px;flex-shrink:0}
.btn-link{display:inline-flex;align-items:center;gap:6px;font-size:.9rem;font-weight:500;color:var(--blue);transition:gap .2s}
.btn-link:hover{gap:10px}
.hero-tags{display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;opacity:0;animation:fadeUp .9s var(--ease) 1.2s forwards}
.hero-tag{font-size:.72rem;font-weight:500;color:var(--ink-4);background:var(--card);border:1px solid var(--line-hi);padding:5px 13px;border-radius:20px;transition:border-color .2s,color .2s,transform .2s}
.hero-tag:hover{border-color:var(--blue);color:var(--blue);transform:translateY(-1px)}

/* floating dash */
.hero-dash-wrap{margin-top:52px;opacity:0;animation:floatIn 1.2s var(--spring) 1.35s forwards;position:relative;display:inline-block}
@keyframes floatIn{from{opacity:0;transform:translateY(40px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.hero-dash-wrap::before{content:'';position:absolute;bottom:-30px;left:50%;transform:translateX(-50%);width:70%;height:40px;background:radial-gradient(ellipse,rgba(0,113,227,.18),transparent 70%);pointer-events:none;filter:blur(8px)}
.hero-dash{background:var(--card);border-radius:20px;overflow:hidden;border:1px solid var(--line-hi);box-shadow:0 4px 24px rgba(0,0,0,.06),0 32px 80px rgba(0,0,0,.1);text-align:left;width:700px;max-width:100%;animation:float 6s ease-in-out infinite 2.5s}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.dash-bar{background:var(--bg);padding:13px 18px;display:flex;align-items:center;gap:7px;border-bottom:1px solid var(--line-hi)}
.db{width:9px;height:9px;border-radius:50%}.db-r{background:#ff5f57}.db-y{background:#febc2e}.db-g{background:#28c840}
.dash-url{margin-left:8px;flex:1;background:var(--line-hi);border-radius:5px;height:20px;display:flex;align-items:center;justify-content:center;font-size:.62rem;color:var(--ink-4)}
.dash-body{padding:22px}
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
.kpi{background:var(--bg);border-radius:12px;padding:14px}
.kpi-lbl{font-size:.6rem;font-weight:600;color:var(--ink-4);text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px}
.kpi-val{font-size:1.6rem;font-weight:800;letter-spacing:-.03em;color:var(--ink);line-height:1}
.kpi-val span{font-size:.9rem;color:var(--ink-4);font-weight:500}
.kpi-delta{font-size:.65rem;font-weight:500;color:var(--green);margin-top:4px}
.chart{background:var(--bg);border-radius:12px;padding:14px;margin-bottom:12px}
.chart-lbl{font-size:.6rem;font-weight:600;color:var(--ink-4);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px}
.bars{display:flex;align-items:flex-end;gap:5px;height:54px}
.b{flex:1;border-radius:3px 3px 0 0;background:var(--blue-lo)}.b.hi{background:var(--blue)}
.chips{display:flex;gap:8px}
.chip{flex:1;background:var(--bg);border-radius:10px;padding:9px 11px;font-size:.62rem;font-weight:500;color:var(--ink-3);display:flex;align-items:center;gap:6px}
.cdot{width:6px;height:6px;border-radius:50%;flex-shrink:0}.cdot-b{background:var(--blue)}.cdot-g{background:var(--green)}.cdot-gr{background:var(--ink-4)}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}

/* ────── SECTIONS ────── */
section{padding:100px 24px}
.wrap{max-width:980px;margin:0 auto}
.eyebrow{font-size:.78rem;font-weight:600;color:var(--blue);margin-bottom:12px}
.h2{font-size:clamp(2rem,3.8vw,3.2rem);font-weight:800;letter-spacing:-.04em;line-height:1.07;color:var(--ink);margin-bottom:16px}
.body-text{font-size:1.05rem;line-height:1.72;color:var(--ink-3);max-width:540px}

/* ────── HOW IT WORKS ────── */
#how{background:var(--bg)}
.how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line-hi);border:1px solid var(--line-hi);border-radius:20px;overflow:hidden;margin-top:52px}
.how-step{background:var(--card);padding:40px 32px;position:relative;transition:background .25s}
.how-step:hover{background:#fafafe}
.step-line{position:absolute;top:52px;right:-1px;width:1px;height:40px;background:linear-gradient(to bottom,var(--blue),transparent);opacity:.4}
.how-step:last-child .step-line{display:none}
.step-num{font-size:.68rem;font-weight:700;color:var(--blue);letter-spacing:.08em;margin-bottom:20px;display:flex;align-items:center;gap:8px}
.step-num::before{content:'';display:block;width:20px;height:1px;background:var(--blue)}
.step-icon{width:48px;height:48px;background:var(--blue-lo);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;color:var(--blue);transition:background .3s,transform .3s var(--spring)}
.how-step:hover .step-icon{background:var(--blue);color:#fff;transform:scale(1.08)}
.step-icon svg{width:22px;height:22px}
.how-step h3{font-size:1.1rem;font-weight:700;letter-spacing:-.02em;color:var(--ink);margin-bottom:10px}
.how-step p{font-size:.88rem;line-height:1.68;color:var(--ink-3)}
.step-tag{display:inline-block;margin-top:16px;font-size:.68rem;font-weight:600;color:var(--blue);background:var(--blue-lo);padding:4px 10px;border-radius:20px}

/* ────── DATA ────── */
#data{background:var(--surface)}
.data-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.stat-row{display:flex;gap:36px;margin-top:36px;padding-top:32px;border-top:1px solid var(--line-hi);flex-wrap:wrap}
.stat-num{font-size:clamp(2.2rem,3.5vw,3.2rem);font-weight:800;letter-spacing:-.04em;color:var(--blue);line-height:1;margin-bottom:4px}
.stat-label{font-size:.8rem;color:var(--ink-3);margin-top:4px}

/* ────── RESULTS ────── */
#results{background:var(--bg)}
.results-header{margin-bottom:52px}
.results-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.result-card{background:var(--card);border:1px solid var(--line-hi);border-radius:20px;padding:32px 28px;transition:box-shadow .3s,transform .3s;position:relative;overflow:hidden}
.result-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--blue),#34aaff);transform:scaleX(0);transform-origin:left;transition:transform .4s var(--ease)}
.result-card:hover{box-shadow:0 12px 40px rgba(0,0,0,.09);transform:translateY(-4px)}
.result-card:hover::before{transform:scaleX(1)}
.result-sector{display:inline-flex;align-items:center;gap:6px;font-size:.68rem;font-weight:600;color:var(--ink-3);background:var(--bg);padding:5px 11px;border-radius:20px;margin-bottom:20px;letter-spacing:.02em}
.result-sector-dot{width:5px;height:5px;border-radius:50%;background:var(--blue)}
.result-location{font-size:.78rem;color:var(--ink-4);margin-bottom:24px;font-weight:500}
.result-metrics{display:flex;flex-direction:column;gap:12px;margin-bottom:24px}
.result-metric{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--bg);border-radius:10px}
.result-metric-label{font-size:.8rem;color:var(--ink-3)}
.result-metric-val{font-size:1rem;font-weight:700;color:var(--ink);letter-spacing:-.02em}
.result-metric-val.blue{color:var(--blue)}
.result-metric-val.green{color:var(--green)}
.result-quote{font-size:.85rem;line-height:1.65;color:var(--ink-3);padding-top:20px;border-top:1px solid var(--line-hi);font-style:italic}
.result-timeframe{font-size:.7rem;font-weight:600;color:var(--ink-4);text-transform:uppercase;letter-spacing:.08em;margin-top:16px}

/* ────── SYSTEM ────── */
#system{background:var(--surface)}
.sys-hd{margin-bottom:52px}
.cards{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.sc{background:var(--card);border:1px solid var(--line-hi);border-radius:18px;padding:32px 24px 28px;transition:box-shadow .3s,transform .3s,border-color .3s;position:relative;overflow:hidden}
.sc::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--blue);transform:scaleX(0);transform-origin:left;transition:transform .3s var(--ease)}
.sc:hover{box-shadow:0 10px 40px rgba(0,0,0,.09);transform:translateY(-4px);border-color:rgba(0,113,227,.2)}
.sc:hover::after{transform:scaleX(1)}
.sc:hover .sc-icon{background:var(--blue);color:#fff;transform:scale(1.08) rotate(-4deg)}
.sc-num{font-size:.68rem;font-weight:600;color:var(--blue);letter-spacing:.04em;margin-bottom:22px}
.sc-icon{width:42px;height:42px;background:var(--blue-lo);border-radius:11px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;color:var(--blue);transition:background .3s,color .3s,transform .3s var(--spring)}
.sc-icon svg{width:18px;height:18px}
.sc h3{font-size:1.05rem;font-weight:700;letter-spacing:-.02em;color:var(--ink);margin-bottom:10px}
.sc p{font-size:.85rem;line-height:1.65;color:var(--ink-3)}

/* ────── EXCLUSIVITY ────── */
#excl{background:var(--bg)}
.excl-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.terr-card{background:var(--card);border-radius:24px;border:1px solid var(--line-hi);padding:32px;box-shadow:0 4px 20px rgba(0,0,0,.05)}
.terr-title{font-size:.72rem;font-weight:700;color:var(--ink-4);margin-bottom:18px;letter-spacing:.06em;text-transform:uppercase}
.terr-input-row{display:flex;gap:10px;margin-bottom:20px}
.terr-input{flex:1;background:var(--bg);border:1.5px solid var(--line);border-radius:12px;padding:12px 16px;font-family:var(--font);font-size:.92rem;font-weight:500;color:var(--ink);outline:none;transition:border-color .2s,box-shadow .2s}
.terr-input::placeholder{color:var(--ink-4)}
.terr-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(0,113,227,.1)}
.terr-btn{background:var(--blue);color:#fff;border-radius:10px;padding:12px 18px;font-size:.85rem;font-weight:600;font-family:var(--font);transition:background .2s,transform .15s;flex-shrink:0}
.terr-btn:hover{background:var(--blue-hi);transform:scale(1.02)}
.terr-res{border-radius:12px;padding:13px 16px;font-size:.88rem;font-weight:500;display:none;align-items:center;gap:10px;animation:fadeUp .4s var(--ease) forwards}
.terr-res.free{background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;display:flex}
.terr-res.taken{background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;display:flex}
.terr-res.loading{background:var(--bg);border:1px solid var(--line-hi);color:var(--ink-3);display:flex}
.tr-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.tr-dot-g{background:#22c55e}.tr-dot-r{background:#f97316}.tr-dot-l{background:var(--ink-4)}
.terr-map{position:relative;height:170px;background:var(--bg);border-radius:14px;border:1px solid var(--line-hi);overflow:hidden;margin-top:16px}
.terr-map::before{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--line-hi) 1px,transparent 1px),linear-gradient(90deg,var(--line-hi) 1px,transparent 1px);background-size:28px 28px;opacity:.7}
.map-rings{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
.mr{position:absolute;border-radius:50%;border:1.5px solid rgba(0,113,227,.2);transition:all .5s var(--ease)}
.mr1{width:120px;height:120px}.mr2{width:76px;height:76px;border-color:rgba(0,113,227,.35)}.mr3{width:36px;height:36px;border-color:rgba(0,113,227,.5)}
.mc{width:14px;height:14px;border-radius:50%;background:var(--blue);box-shadow:0 0 0 4px rgba(0,113,227,.18);position:relative;z-index:2;transition:background .3s,box-shadow .3s}
.mr.taken{border-color:rgba(249,115,22,.3)}.mc.taken{background:#f97316;box-shadow:0 0 0 4px rgba(249,115,22,.18)}
.excl-note{background:var(--card);border:1px solid var(--line-hi);border-left:3px solid var(--blue);border-radius:10px;padding:16px 20px;font-size:.88rem;line-height:1.65;color:var(--ink-3);margin:24px 0 32px}

/* ────── POSITIONING ────── */
#pos{background:var(--ink);color:#fff}
#pos .eyebrow{color:#6ab0ff}
#pos .h2{color:#fff}
#pos .body-text{color:rgba(255,255,255,.54)}
.pos-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
.pos-quote{font-size:1.05rem;line-height:1.72;color:rgba(255,255,255,.72);margin-top:24px;padding-left:20px;border-left:2px solid rgba(255,255,255,.15)}
.blist{display:flex;flex-direction:column;gap:1px;border:1px solid rgba(255,255,255,.1);border-radius:16px;overflow:hidden}
.bi{display:flex;align-items:center;gap:14px;padding:20px 24px;background:rgba(255,255,255,.04);font-size:.92rem;font-weight:500;color:rgba(255,255,255,.82);border-bottom:1px solid rgba(255,255,255,.07);transition:background .2s,padding-left .2s}
.bi:last-child{border-bottom:none}.bi:hover{background:rgba(255,255,255,.08);padding-left:30px}
.bi-icon{width:30px;height:30px;background:rgba(0,113,227,.22);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#6ab0ff;flex-shrink:0;transition:background .2s}
.bi:hover .bi-icon{background:rgba(0,113,227,.4)}.bi-icon svg{width:13px;height:13px}

/* ────── FAQ ────── */
#faq{background:var(--surface)}
.faq-wrap{max-width:680px;margin:0 auto}
.faq-hd{margin-bottom:48px}
.faq-item{border-bottom:1px solid var(--line-hi)}.faq-item:first-of-type{border-top:1px solid var(--line-hi)}
.faq-q{width:100%;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:22px 0;font-size:.98rem;font-weight:500;color:var(--ink);text-align:left;transition:color .2s}
.faq-q:hover{color:var(--blue)}.faq-q.open{color:var(--blue)}
.faq-chev{width:24px;height:24px;flex-shrink:0;color:var(--ink-4);transition:transform .35s var(--ease),color .2s;background:var(--bg);border-radius:50%;display:flex;align-items:center;justify-content:center}
.faq-chev svg{width:12px;height:12px}
.faq-q.open .faq-chev{transform:rotate(180deg);color:var(--blue);background:var(--blue-lo)}
.faq-ans{max-height:0;overflow:hidden;transition:max-height .45s var(--ease)}
.faq-ans.open{max-height:260px}
